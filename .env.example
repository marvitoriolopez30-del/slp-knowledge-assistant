# ==================== SUPABASE ====================
# Get these from Supabase Dashboard → Settings → API

# Your Supabase project URL
# Example: https://your-project.supabase.co
VITE_SUPABASE_URL=https://your_project.supabase.co
SUPABASE_URL=https://your_project.supabase.co

# Supabase Anonymous Key (public, safe for frontend)
# Get from: Settings → API → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (SECRET - backend only!)
# Get from: Settings → API → service_role secret
# ⚠️  NEVER commit this to git or expose in frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==================== OPENAI ====================
# Get this from https://platform.openai.com/account/api-keys

# OpenAI API Key (SECRET - backend only!)
# ⚠️  NEVER commit this to git
OPENAI_API_KEY=sk-proj-abc123xyz789...

# ==================== DEPLOYMENT ====================
NODE_ENV=development
PORT=3000

# ==================== INSTRUCTIONS ====================
# 1. Copy this file to .env.local
# 2. Fill in all REQUIRED values from Supabase and OpenAI
# 3. NEVER commit .env.local to git
# 4. Add .env.local to .gitignore
# 5. For Vercel deployment, add these as secrets in Vercel dashboard
